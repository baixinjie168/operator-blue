{
  "__Description__": "defines the mapping from role names to data generation schemes.",
  "__ROLE_ONTOLOGY_DOC__": [
    "role_data_generic",
    "role_data_positive_only",
    "role_scale_param",
    "role_bias_param",
    "role_index_tensor",
    "role_quant_scale",
    "role_quant_offset",
    "role_epsilon_float",
    "role_shape_attribute",
    "role_unclassified"
  ],
    "__GENERATOR_RULES_LEGEND__": {
    "__comment__": "非功能性的注释，解释生成器 (data_profile_logic.py) 所支持的 'type' 字段，即数据生成策略。",
    "Static": "生成一个静态的常量值。需要 `value` 参数 (例如: 0.0, 'NaN', 'Infinity')。",
    "Normal": "从正态 (高斯) 分布中采样。需要 `mean` (均值) 和 `std` (标准差) 参数。",
    "Uniform": "从均匀分布 (浮点数) 中采样。需要 `min` (最小值) 和 `max` (最大值) 参数。",
    "LogUniform": "从对数均匀分布中采样 (在数量级上均匀，用于压力测试)。需要 `min` 和 `max` 参数。",
    "IntUniform": "从均匀分布 (整数) 中采样。需要 `min` 和 `max` 参数。",
    "IntUniformOdd": "从均匀分布中仅采样“奇数”整数 (用于测试内存对齐)。需要 `min` 和 `max` 参数。",
    "Choice": "从一个给定的 `options` 列表 (数组) 中随机选择一个值。"
  },

  "role_data_generic": {
    "Typical": [
      {"type": "Normal", "mean": 0, "std": 1, "weight": 0.50, "comment": "标准正态分布 (最常见的通用数据分布)"},
      {"type": "Uniform", "min": -10, "max": 10, "weight": 0.30, "comment": "小范围均匀分布覆盖"},
      {"type": "Normal", "mean": 0, "std": 5, "weight": 0.20, "comment": "宽标准差正态 (模拟方差较大的激活值)"}
    ],
    "PosNormal": [
      {"type": "Normal", "mean": 5, "std": 2, "post_process": "abs_clip_min", "clip_min": 0.01, "weight": 0.33},
      {"type": "LogUniform", "min": 0.01, "max": 100, "weight": 0.33},
      {"type": "Normal", "mean": 0, "std": 1.5, "post_process": "abs_clip_min", "clip_min": 0.01, "weight": 0.34, "comment": "测试 '零均值' 数据 (例如来自LayerNorm后的 ReLU)"}
    ],
    "NegNormal": [
      {"type": "Normal", "mean": -5, "std": 2, "post_process": "clip_max", "clip_max": -0.01, "weight": 0.33},
      {"type": "LogUniform", "min": -100, "max": -0.01, "weight": 0.33},
      { "type": "Normal", "mean": 0, "std": 1.5, "post_process": "clip_max", "clip_max": -0.01,  "weight": 0.34, "comment": "测试 '零均值' 数据 (例如来自Normalization后的Sigmoid/Tanh的负半轴)"}
    ],
    "Zero": [{"type": "Static", "value": 0.0, "weight": 1.0}],
    "One": [{"type": "Static", "value": 1.0, "weight": 1.0}],
    "NaN": [{"type": "Static", "value": "NaN", "weight": 1.0}],
    "PosInf": [{"type": "Static", "value": "Infinity", "weight": 1.0}],
    "NegInf": [{"type": "Static", "value": "-Infinity", "weight": 1.0}],
    "SubNormal": [{"type": "Static", "value": 1.23e-40, "weight": 1.0}],
    "Pos": [
      {"type": "Normal", "mean": 10, "std": 5, "post_process": "abs_clip_min", "clip_min": 1, "weight": 0.30, "comment": "模拟量化后的正激活值 (离散化高斯, 截断取整)"},
      {"type": "IntUniform", "min": 1, "max": 100, "weight": 0.15, "comment": "小正整数均匀覆盖 (高频区间)"},
      {"type": "IntUniform", "min": 101, "max": 32767, "weight": 0.15, "comment": "中大正整数均匀覆盖"},
      {"type": "Choice", "options": [1, 2, 4, 8, 16, 32, 64, 128, 256], "weight": 0.20, "comment": "2的幂次 (常见于通道数/batch size等架构参数)"},
      {"type": "IntUniformOdd", "min": 1, "max": 255, "weight": 0.10, "comment": "奇数正整数 (测试非对齐场景)"},
      {"type": "Choice", "options": [3, 7, 15, 31, 63, 127, 255], "weight": 0.10, "comment": "2^n-1 边界值 (常见的整数溢出临界点)"}
    ],
    "Neg": [
      {"type": "Normal", "mean": -10, "std": 5, "post_process": "clip_max", "clip_max": -1, "weight": 0.30, "comment": "模拟量化后的负激活值 (离散化高斯, 截断取整)"},
      {"type": "IntUniform", "min": -100, "max": -1, "weight": 0.15, "comment": "小负整数均匀覆盖 (高频区间)"},
      {"type": "IntUniform", "min": -32767, "max": -101, "weight": 0.15, "comment": "中大负整数均匀覆盖"},
      {"type": "Choice", "options": [-1, -2, -4, -8, -16, -32, -64, -128, -256], "weight": 0.20, "comment": "负的2的幂次"},
      {"type": "IntUniformOdd", "min": -255, "max": -1, "weight": 0.10, "comment": "奇数负整数 (测试非对齐场景)"},
      {"type": "Choice", "options": [-3, -7, -15, -31, -63, -127, -255], "weight": 0.10, "comment": "-(2^n-1) 边界值"}
    ],
    "Max": [{"type": "Static", "value": 2147483647, "weight": 1.0, "comment": "INT32 最大值边界"}],
    "Min": [{"type": "Static", "value": -2147483648, "weight": 1.0, "comment": "INT32 最小值边界"}]
  },

